text = "Features:
Sleeping: Crib/Baby cot (available on request), Bunk beds, Sofa bed, Interconnecting rooms.

Dining: High chair, Electric kettle (for formula), Microwave, Kids' cutlery/plates.

Entertainment: Kids' TV channels, Board games/Puzzles, Game console, Dedicated play area.

Convenience: Laundry facilities (Washer/Dryer), Bathtub (easier for washing toddlers than a shower), Diaper disposal bin."
height = 256.0

[node name="FoldableText2" parent="MarginContainer/VBoxContainer/ScrollContainer/VBoxContainer" unique_id=757355733 instance=ExtResource("5_66y8n")]
custom_minimum_size = Vector2(0, 256)
layout_mode = 2
text = "Accessibility:
Safety: Socket covers/protectors, Corner guards on furniture, Window locks/Safety catches, Safety gates for stairs.

Mobility: Stroller-accessible entrances, Wide elevators, Ramps (no-step access for strollers).

Bathroom Safety: Non-slip bath mats, Step stools for the sink.

Allergy-Friendly: Hypoallergenic linens, Carpet-free floors (hardwood or parquet) to reduce dust mites."
height = 256.0
